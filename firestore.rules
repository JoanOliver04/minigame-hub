rules_version = '2';

// Multiplayer rooms for the Mini-Game Hub (all 27 games).
//
// Model: rooms/{code}, code IS the document id (never enumerable — `list`
// is disabled below, so a room is only reachable by already knowing its
// code). These rules enforce WHO can write and WHEN (seat membership, turn
// ownership) — they do not re-validate full game legality independently of
// the client's Firestore transaction (see src/games/*/room.ts). That is an
// accepted trade-off for a casual friends hub with no server compute
// (Firebase Spark / free plan, no Cloud Functions).
//
// Expiry: every room carries `expiresAt` (createdAt + 24h). Physical
// deletion via a Firestore TTL policy is OPTIONAL. Normal user-closed rooms
// are physically deleted by `leaveRoom()` so they do not leave abandoned
// documents behind. Expiry still protects stale rooms by denying further
// updates after `expiresAt`; seated players may still delete their own stale
// room as cleanup.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSeated(room) {
      return request.auth.uid in room.players;
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function notExpired(room) {
      return room.expiresAt > request.time;
    }

    function validGameId(gameId) {
      return gameId in ["rps", "ttt", "penalty-kick", "basket-shot", "guess", "higher-or-lower", "connect-four", "memory-match", "nim", "word-guess", "blackjack", "prism-clash", "property-baron", "parchis", "goose-game", "tile-rummy", "reaction-time", "fleet-command", "shadow-protocol", "windline-archery", "beat-reactor", "circuit-breaker", "neon-drift", "signal-breaker", "diceforge-arena", "hex-dominion", "spellstorm"];
    }

    function validInGameStatusTransition() {
      return request.resource.data.status == resource.data.status
        || (resource.data.status == "playing" && request.resource.data.status == "finished")
        || (
          resource.data.status == "finished"
          && request.resource.data.status == "playing"
          && request.resource.data.rematchVotes == {}
          && resource.data.rematchVotes.keys().hasAll(resource.data.players.keys())
        );
    }

    function validRematchVotesTransition() {
      return request.resource.data.rematchVotes == resource.data.rematchVotes
        || (
          resource.data.status == "finished"
          && request.resource.data.status == "finished"
          && request.resource.data.rematchVotes.diff(resource.data.rematchVotes).affectedKeys().hasOnly([request.auth.uid])
          && request.resource.data.rematchVotes[request.auth.uid] == true
        )
        || (
          resource.data.status == "finished"
          && request.resource.data.status == "playing"
          && request.resource.data.rematchVotes == {}
          && resource.data.rematchVotes.keys().hasAll(resource.data.players.keys())
        );
    }

    function validInGameChangedFields() {
      return (
          resource.data.status == "playing"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["game", "status", "updatedAt"])
        )
        || (
          resource.data.status == "finished"
          && request.resource.data.status == "finished"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["rematchVotes", "updatedAt"])
        )
        || (
          resource.data.status == "finished"
          && request.resource.data.status == "playing"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["game", "status", "rematchVotes", "updatedAt"])
        );
    }

    match /rooms/{code} {
      allow get: if isSignedIn();
      allow list: if false;

      // Create: only the host, seated alone, room starts in "waiting", and
      // (defense in depth) can't be born already expired.
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.status == "waiting"
        && validGameId(request.resource.data.gameId)
        && request.resource.data.players.keys().hasOnly([request.auth.uid])
        && request.resource.data.rematchVotes == {}
        && request.resource.data.expiresAt > request.time;

      allow update: if isSignedIn() && notExpired(resource.data) && (
        // Join: room currently has exactly the host, joiner adds themself,
        // flips status to "playing". Host/gameId/code are immutable.
        (
          resource.data.status == "waiting"
          && resource.data.players.size() == 1
          && !(request.auth.uid in resource.data.players)
          && request.resource.data.players.keys().hasAll(resource.data.players.keys())
          && request.auth.uid in request.resource.data.players
          && request.resource.data.status == "playing"
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
          && unchanged("gameSettings")
          && unchanged("rematchVotes")
          && unchanged("createdAt")
          && unchanged("expiresAt")
        )
        ||
        // Host game switch: keep the same room code and seated players,
        // replace the opaque game payload with the selected game's fresh
        // seed, clear rematch votes, and keep status joinable/playing based
        // on how many players are seated.
        (
          isSeated(resource.data)
          && request.auth.uid == resource.data.hostUid
          && validGameId(request.resource.data.gameId)
          && unchanged("hostUid")
          && unchanged("code")
          && unchanged("players")
          && unchanged("createdAt")
          && unchanged("expiresAt")
          && request.resource.data.rematchVotes == {}
          && (
            (resource.data.players.size() == 1 && request.resource.data.status == "waiting")
            || (resource.data.players.size() == 2 && request.resource.data.status == "playing")
          )
        )
        ||
        // In-game write (move submission, round/rematch resolution): only a
        // seated player, and the room's identity fields never change.
        (
          isSeated(resource.data)
          && resource.data.status in ["playing", "finished"]
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
          && unchanged("gameSettings")
          && unchanged("players")
          && unchanged("createdAt")
          && unchanged("expiresAt")
          && validInGameStatusTransition()
          && validRematchVotesTransition()
          && validInGameChangedFields()
          // Generic turn-based guard: any per-game payload that carries a
          // `turn` field can only be written by the uid whose turn it is.
          // Games without a `turn` field (e.g. simultaneous-move RPS) skip
          // this check entirely — future turn-based games get it for free
          // just by naming their field `turn`, no rule change needed.
          && (
            !("turn" in resource.data.game)
            || resource.data.game.turn == null
            || resource.data.game.finished == true
            || request.auth.uid == resource.data.game.turn
          )
        )
        ||
        // Legacy leave path: older clients may still flip status to
        // "abandoned"; current clients delete the document instead.
        (
          isSeated(resource.data)
          && request.resource.data.status == "abandoned"
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
          && unchanged("gameSettings")
          && unchanged("players")
          && unchanged("rematchVotes")
          && unchanged("createdAt")
          && unchanged("expiresAt")
        )
      );

      // Close room: only a seated player can delete the room document.
      // No list access exists, so this does not create an enumerable cleanup
      // endpoint; it just prevents closed rooms from leaving residue.
      allow delete: if isSignedIn() && isSeated(resource.data);
    }
  }
}
