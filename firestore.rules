rules_version = '2';

// Multiplayer rooms for the Mini-Game Hub (RPS + Tic-Tac-Toe MVP).
//
// Model: rooms/{code}, code IS the document id (never enumerable — `list`
// is disabled below, so a room is only reachable by already knowing its
// code). These rules enforce WHO can write and WHEN (seat membership, turn
// ownership) — they do not re-validate full game legality independently of
// the client's Firestore transaction (see src/games/*/room.ts). That is an
// accepted trade-off for a casual friends hub with no server compute
// (Firebase Spark / free plan, no Cloud Functions).
//
// Expiry: every room carries `expiresAt` (createdAt + 24h). Physical
// deletion via a Firestore TTL policy is OPTIONAL and currently NOT
// enabled — TTL policies are gated behind billing being enabled on this
// project, and we're not upgrading off Spark just for housekeeping. Instead
// this is "soft expiry": `notExpired()` below denies every write on an
// expired room (join/move/rematch/leave), so an expired room simply
// freezes in place — un-writable, still readable so the UI can show a
// clear "this room has expired" message — until someone enables TTL later
// (a purely additive, non-breaking change) or the doc is manually cleared.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSeated(room) {
      return request.auth.uid in room.players;
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function notExpired(room) {
      return room.expiresAt > request.time;
    }

    match /rooms/{code} {
      allow get: if isSignedIn();
      allow list: if false;

      // Create: only the host, seated alone, room starts in "waiting", and
      // (defense in depth) can't be born already expired.
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.status == "waiting"
        && request.resource.data.gameId in ["rps", "ttt", "penalty-kick", "basket-shot", "guess", "higher-or-lower", "connect-four", "memory-match", "nim", "word-guess", "blackjack", "reaction-time", "fleet-command", "shadow-protocol", "windline-archery", "beat-reactor", "circuit-breaker", "neon-drift"]
        && request.resource.data.players.keys().hasOnly([request.auth.uid])
        && request.resource.data.expiresAt > request.time;

      allow update: if isSignedIn() && notExpired(resource.data) && (
        // Join: room currently has exactly the host, joiner adds themself,
        // flips status to "playing". Host/gameId/code are immutable.
        (
          resource.data.status == "waiting"
          && resource.data.players.size() == 1
          && !(request.auth.uid in resource.data.players)
          && request.resource.data.players.keys().hasAll(resource.data.players.keys())
          && request.auth.uid in request.resource.data.players
          && request.resource.data.status == "playing"
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
        )
        ||
        // In-game write (move submission, round/rematch resolution): only a
        // seated player, and the room's identity fields never change.
        (
          isSeated(resource.data)
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
          && unchanged("players")
          // Generic turn-based guard: any per-game payload that carries a
          // `turn` field can only be written by the uid whose turn it is.
          // Games without a `turn` field (e.g. simultaneous-move RPS) skip
          // this check entirely — future turn-based games get it for free
          // just by naming their field `turn`, no rule change needed.
          && (
            !("turn" in resource.data.game)
            || resource.data.game.turn == null
            || resource.data.game.finished == true
            || request.auth.uid == resource.data.game.turn
          )
        )
        ||
        // Leave: a seated player may only flip status to "abandoned".
        (
          isSeated(resource.data)
          && request.resource.data.status == "abandoned"
          && unchanged("hostUid")
          && unchanged("gameId")
          && unchanged("code")
          && unchanged("players")
        )
      );

      // No TTL policy enabled (see note above) — physical cleanup is
      // deliberately out of scope; soft expiry above is what actually
      // protects the app. Deletes stay disallowed either way.
      allow delete: if false;
    }
  }
}
